# ─────────────────────────────────────────────
#  ORDER MANAGEMENT SYSTEM
#  Environment Variables Template
#
#  HOW TO USE:
#  1. Copy this file and rename it to:  .env.local
#  2. Fill in your own Supabase credentials
#  3. NEVER commit .env.local to Git
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Get these from: Supabase Dashboard → Your Project → Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ── Optional: Steadfast Courier API ───────────
# Required only if you use the Steadfast courier integration
# Get from: https://steadfast.com.bd → API Settings

VITE_STEADFAST_API_KEY=YOUR_STEADFAST_API_KEY
VITE_STEADFAST_SECRET_KEY=YOUR_STEADFAST_SECRET_KEY

# ── Optional: VAPID Keys for Push Notifications ─
# Generate with:  npx web-push generate-vapid-keys
# Then paste the PUBLIC key here, and add PRIVATE key as a Supabase Edge Function secret

VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
